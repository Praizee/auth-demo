# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────
# Get this from your MongoDB Atlas cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
# Use a long, random string — e.g. openssl rand -hex 64
JWT_SECRET=replace_with_a_very_long_random_secret
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# CORS (optional extra origins, comma-separated)
# ─────────────────────────────────────────────
# EXTRA_ORIGINS=http://localhost:3000,https://your-staging-url.vercel.app
